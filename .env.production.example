APP_NAME="E-Service"
APP_ENV=production
APP_KEY=base64:GENERATE_NEW_KEY_WITH_php_artisan_key:generate
APP_DEBUG=false
APP_URL=https://your-domain.com
APP_TIMEZONE=Asia/Makassar

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# Database Configuration
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=eservice_production
DB_USERNAME=your_db_username
DB_PASSWORD=your_secure_db_password

# Session Configuration
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Queue Configuration
# Gunakan 'database' untuk queue driver
# Untuk performa lebih baik, gunakan 'redis'
QUEUE_CONNECTION=database

# Cache Configuration
CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

# Redis Configuration (Opsional, untuk performa lebih baik)
# Uncomment jika menggunakan Redis untuk queue atau cache
# REDIS_CLIENT=phpredis
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379

# Mail Configuration
# PENTING: Gunakan SMTP production yang reliable
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-production-email@domain.com
MAIL_PASSWORD=your-app-specific-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="your-production-email@domain.com"
MAIL_FROM_NAME="E-Service Teknik Informatika"

# AWS Configuration (Jika menggunakan S3 untuk storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Telescope Configuration
# Untuk production, sebaiknya disabled atau hanya untuk admin
TELESCOPE_ENABLED=false
TELESCOPE_DRIVER=database

# TI Unima API Configuration
# Sesuaikan dengan API production
TI_UNIMA_API_URL=https://ti-unima-production.com/api/mahasiswa
TI_UNIMA_API_TOKEN=your-production-api-token

# ============================================
# CATATAN PENTING UNTUK PRODUCTION
# ============================================
#
# 1. APP_DEBUG harus false
# 2. APP_ENV harus production
# 3. Generate APP_KEY baru: php artisan key:generate
# 4. Gunakan password database yang kuat
# 5. Gunakan HTTPS (APP_URL dengan https://)
# 6. Setup MAIL dengan SMTP yang reliable
# 7. Untuk performa lebih baik, gunakan Redis:
#    - QUEUE_CONNECTION=redis
#    - CACHE_STORE=redis
# 8. File .env harus chmod 600 untuk keamanan:
#    chmod 600 .env
# 9. Jangan commit file .env ke Git!
# 10. Setup Supervisor untuk queue workers
#
# ============================================
# QUEUE WORKERS DENGAN SUPERVISOR
# ============================================
#
# Setelah setup .env, pastikan Supervisor sudah dikonfigurasi:
#
# 1. Copy file konfigurasi:
#    sudo cp deployment/supervisor/eservice-worker.conf /etc/supervisor/conf.d/
#
# 2. Edit dan sesuaikan path:
#    sudo nano /etc/supervisor/conf.d/eservice-worker.conf
#
# 3. Update supervisor:
#    sudo supervisorctl reread
#    sudo supervisorctl update
#    sudo supervisorctl start eservice-worker:*
#
# 4. Verify workers running:
#    sudo supervisorctl status
#
# PENTING: Setiap deployment, restart workers:
#    sudo supervisorctl restart eservice-worker:*
#
# ============================================
